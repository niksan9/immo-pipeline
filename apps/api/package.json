{
  "name": "@dealpilot/api",
  "version": "0.0.0",
  "description": "DealPilot backend API — Hono + better-auth + Drizzle/Postgres.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "tsx --env-file=.env src/index.ts",
    "db:up": "docker compose up -d",
    "db:generate": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file=.env src/db/migrate.ts",
    "auth:generate": "echo 'better-auth schema is hand-maintained on 1.6.x — no compatible CLI release exists. See README.md (better-auth schema regeneration).' && exit 1",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dealpilot/core": "workspace:*",
    "@hono/node-server": "^2.0.10",
    "better-auth": "1.6.23",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.31",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.7"
  }
}
