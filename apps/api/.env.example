# Postgres (dealpilot-db docker container, host port 5434)
DATABASE_URL=postgres://dealpilot:dealpilot_dev_pw@localhost:5434/dealpilot

# Separate database used by the vitest integration suite (same container)
TEST_DATABASE_URL=postgres://dealpilot:dealpilot_dev_pw@localhost:5434/dealpilot_test

# better-auth — generate a real secret for anything but local dev
BETTER_AUTH_SECRET=dev-secret-change-me-0123456789abcdef
BETTER_AUTH_URL=http://localhost:3000

# API server
PORT=3000
