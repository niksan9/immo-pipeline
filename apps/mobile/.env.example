# Base URL of the DealPilot API the app talks to (auth + deal sync).
#
# EXPO_PUBLIC_* vars are statically inlined into the JS bundle by Expo at build
# time, so this must be reachable from the device/simulator running the app:
#   - iOS simulator:            http://localhost:3000
#   - Android emulator:         http://10.0.2.2:3000
#   - physical device (Expo Go): http://<your-machine-LAN-IP>:3000
#
# It must also be an origin the API trusts (see apps/api/src/env.ts →
# trustedOrigins). The native app additionally identifies itself with the
# "dealpilot://" scheme, which the API's expo() plugin trusts.
EXPO_PUBLIC_API_URL=http://localhost:3000
