{
  "expo": {
    "name": "DealPilot",
    "slug": "dealpilot",
    "version": "0.0.0",
    "orientation": "portrait",
    "scheme": "dealpilot",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f7f5f2",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
